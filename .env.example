# ForgeFabrik — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.
#
# Usage:
#   cp .env.example .env
#   # edit .env
#   source .env && cargo run -p cli -- serve --seed 42

# ── Paid / cloud AI backends ─────────────────────────────────────────────────
# Required only when spawning agents with kind=claude
ANTHROPIC_API_KEY=

# Required only when spawning agents with kind=opencode or kind=codex
OPENAI_API_KEY=

# ── Free-tier AI backends (no credit card required) ──────────────────────────

# Groq Cloud — fast Llama 3 / Gemma 2 inference
# Sign up at https://console.groq.com  (free, no CC)
# kind=groq
GROQ_API_KEY=

# Cerebras — ultra-fast RDU inference
# Sign up at https://cloud.cerebras.ai  (free, no CC)
# kind=cerebras
CEREBRAS_API_KEY=

# SambaNova Cloud — Llama 3.3 70B, DeepSeek V3
# Sign up at https://cloud.sambanova.ai  (free, no CC)
# kind=sambanova
SAMBANOVA_API_KEY=

# OpenRouter — many free models (suffix :free in model id)
# Sign up at https://openrouter.ai/keys  (free account)
# kind=openrouter
OPENROUTER_API_KEY=

# ── Ollama (local — no key needed) ───────────────────────────────────────────
# Install: https://ollama.com  then:  ollama pull llama3.2
# kind=ollama
#
# Override base URL if Ollama runs on a different host/port:
# OLLAMA_BASE_URL=http://localhost:11434/v1
#
# Override the default model (default: llama3.2):
# OLLAMA_MODEL=llama3.2

# ── Logging ──────────────────────────────────────────────────────────────────
# Filter syntax: https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/
# RUST_LOG=forgefabrik=debug

# ── Server ───────────────────────────────────────────────────────────────────
# Defaults used by  cargo run -p cli -- serve
# PORT=8080
# SEED=42
